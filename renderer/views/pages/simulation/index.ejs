<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../../common/head'); %>
  <style>
    body {
    font-family: Arial, sans-serif;
    text-align: center;
    margin: 0;
    padding: 0;
    }
    #canvas-container {
        display: inline-block;
        margin-top: 20px;
    }
    input[type=range] {
        width: 200px;
    }
    label {
        margin-right: 2px;
    }
    div {
        margin: 10px;
    }
      #graphContainer {
            text-align: center;
        }
        table {
            width: 100%;
            border-collapse: collapse;
        }
        td {
            text-align: center;
            position: relative;
            width: 50px; 
        }
        td::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 2px;
            background-color: rgb(255, 255, 255); 
            z-index: -1;
        }
        .marker {
            position: relative;
            z-index: 1;
        }
        .controls {
            margin: auto;
            display: block;
        }
        .cursor {
            background-color: rgb(255, 255, 255); 
            width: 5%; 
            height: 20px; 
            display: block;
            margin: auto;
            border-radius: 5px; 
        }
  </style>
</head>
<body class="container bg-dark text-light">

<header>
  <%- include('header'); %>
</header>

<main>
  </div>
</div>
  <script src="/js/simulation.js"></script>
  <button id="btnChart" type="button" class="btn btn-lg btn-primary" style="position:fixed; right:50px; top:50px;" disabled>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-graph-up" viewBox="0 0 16 16">
      <path fill-rule="evenodd" d="M0 0h1v15h15v1H0zm14.817 3.113a.5.5 0 0 1 .07.704l-4.5 5.5a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61 4.15-5.073a.5.5 0 0 1 .704-.07"/>
    </svg>
  </button>
  <div id="graphContainer"></div>
  <div id="canvas-container"></div>
</main>

<footer>
  <%- include('../../common/footer'); %>
</footer>

</body>
</html>